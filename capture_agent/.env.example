# gps-receiverの接続先
# 同一ホストのDockerへ送る場合は127.0.0.1、別サーバならそのIPを指定します。
GPS_RECEIVER_HOST=127.0.0.1
GPS_RECEIVER_PCM_PORT=9010

# PCM形式（gps-receiver側と同じ値にします）
SAMPLE_RATE=48000
SAMPLE_FORMAT=S16_LE
INPUT_CHANNELS=4
GPS_CHANNEL=4

# ホスト側のキャプチャ設定
CAPTURE_DEVICE=hw:2,0
# 任意のコマンドを使う場合だけ設定します。標準出力はraw PCMである必要があります。
# CAPTURE_COMMAND=arecord -D hw:2,0 -f S16_LE -r 48000 -c 2 -t raw

# 接続とログ
AGENT_NAME=sdi-capture-01
CONNECT_TIMEOUT_SECONDS=5
RECONNECT_SECONDS=3
PROGRESS_LOG_SECONDS=10
CHUNK_BYTES=65536
LOG_LEVEL=INFO

# Local control API
CAPTURE_AGENT_CONTROL_SOCKET=run/control.sock

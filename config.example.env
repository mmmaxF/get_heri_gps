# Server
HOST=0.0.0.0
PORT=8010

# Output
OUTPUT_CSV=./output/gps_positions.csv

# SDI/live input.
# This command must write interleaved signed 16-bit little-endian PCM to stdout.
# Example for ALSA capture:
# INPUT_COMMAND=arecord -D hw:2,0 -f S16_LE -r 48000 -c 4 -t raw
INPUT_COMMAND=arecord -D hw:2,0 -f S16_LE -r 48000 -c 2 -t raw
INPUT_CHANNELS=2

# Test mode default capture.
TEST_CAPTURE_DIR=../audio_capture/20260613_132355

# Decoder defaults.
GPS_CHANNEL=2
SAMPLE_RATE=48000
WINDOW_SECONDS=20
DECODE_INTERVAL_SECONDS=1.0

# Server
HOST=0.0.0.0
PORT=8010

# Output
OUTPUT_CSV=./output/gps_positions.csv

# SDI/live input.
# The UI lists ALSA capture devices and builds INPUT_COMMAND automatically.
INPUT_DEVICE=hw:2,0
INPUT_COMMAND=arecord -D hw:2,0 -f S16_LE -r 48000 -c 2 -t raw
INPUT_CHANNELS=2
CAPTURE_DEVICE_INCLUDE_KEYWORDS=AJA,U-TAP,Blackmagic,DeckLink,UltraStudio,SDI,MS2109,USB Audio

# Test mode default capture.
TEST_CAPTURE_DIR=../audio_capture/20260613_132355

# Decoder defaults.
GPS_CHANNEL=2
SAMPLE_RATE=48000
WINDOW_SECONDS=20
DECODE_INTERVAL_SECONDS=1.0

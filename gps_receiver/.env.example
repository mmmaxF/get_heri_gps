# GPS receiver web app
HOST=0.0.0.0
PORT=8010
APP_PUBLIC_HOST=127.0.0.1

# Audio/GPS input
SAMPLE_RATE=48000
GPS_BAUD=1200
GPS_MARK_HZ=1200
GPS_SPACE_HZ=1800
INPUT_DEVICE=hw:2,0
INPUT_CHANNELS=2
GPS_CHANNEL=2
CAPTURE_DEVICE_INCLUDE_KEYWORDS=AJA,U-TAP,Blackmagic,DeckLink,UltraStudio,SDI,MS2109,USB Audio
OUTPUT_CSV=/app/output/gps_positions.csv
WINDOW_SECONDS=20.0
DECODE_INTERVAL_SECONDS=1.0

# Service links
REVERSE_GEOCODER_URL=http://reverse-geocoder:8020/api/position
TELOP_OUTPUT_URL=http://telop-output:8030

# Offline demodulator
GPS_DEMOD_INPUT_DIR=/app/input
GPS_DEMOD_OUTPUT_CSV=/app/output/demodulated_gps.csv
TEST_CAPTURE_DIR=../audio_capture/20260613_132355

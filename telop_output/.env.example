# Telop output API
HOST=0.0.0.0
PORT=8030

# Service links
REVERSE_GEOCODER_LATEST_URL=http://reverse-geocoder:8020/api/latest

# Local config
TELOP_CONFIG_PATH=/app/config/telop_config.json

# Rotating application log
LOG_DIR=/app/logs
LOG_FILE=telop_output.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

# Root orchestration settings for docker-compose.yml
COMPOSE_PROJECT_NAME=get_heri_gps

# Host ports exposed by each container
GPS_RECEIVER_PORT=8010
REVERSE_GEOCODER_PORT=8020
TELOP_OUTPUT_PORT=8030

# Service env files
GPS_RECEIVER_ENV_FILE=./gps_receiver/.env
REVERSE_GEOCODER_ENV_FILE=./reverse_geocoder/.env
TELOP_OUTPUT_ENV_FILE=./telop_output/.env

# Host-side paths mounted into containers
HOST_GPS_OUTPUT_DIR=./gps_receiver/output
HOST_GPS_INPUT_DIR=./gps_receiver/input
HOST_GPS_LOG_DIR=./gps_receiver/logs
HOST_GEOCODER_DATA_DIR=./reverse_geocoder/data
HOST_GEOCODER_OUTPUT_DIR=./reverse_geocoder/output
HOST_GEOCODER_LOG_DIR=./reverse_geocoder/logs
HOST_TELOP_CONFIG_DIR=./telop_output/config
HOST_TELOP_ASSETS_DIR=./telop_output/assets
HOST_TELOP_LOG_DIR=./telop_output/logs

# Docker stdout/stderr log rotation
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3

# Start script display
APP_PUBLIC_HOST=127.0.0.1

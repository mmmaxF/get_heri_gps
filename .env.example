# get_heri_gps common settings
COMPOSE_PROJECT_NAME=get_heri_gps

# Main web app
APP_HOST=0.0.0.0
APP_PORT=8010
APP_PUBLIC_HOST=127.0.0.1

# Audio/GPS input
SAMPLE_RATE=48000
GPS_BAUD=1200
GPS_MARK_HZ=1200
GPS_SPACE_HZ=1800
INPUT_DEVICE=hw:2,0
INPUT_CHANNELS=2
GPS_CHANNEL=2
CAPTURE_DEVICE_INCLUDE_KEYWORDS=AJA,U-TAP,Blackmagic,DeckLink,UltraStudio,SDI,MS2109,USB Audio
OUTPUT_CSV=/app/output/gps_positions.csv
WINDOW_SECONDS=20.0
DECODE_INTERVAL_SECONDS=1.0

# Optional offline demodulator
GPS_DEMOD_INPUT_DIR=/app/input
GPS_DEMOD_OUTPUT_CSV=/app/output/demodulated_gps.csv

# Reverse geocoder
REVERSE_GEOCODER_HOST=0.0.0.0
REVERSE_GEOCODER_PORT=8020
REVERSE_GEOCODER_URL=http://reverse-geocoder:8020/api/position
REVERSE_GEOCODER_LATEST_URL=http://reverse-geocoder:8020/api/latest
GEOCODER_AUTO_UPDATE=1
GEOCODER_UPDATE_DAYS=30
GEOCODER_DATA_URL=https://nlftp.mlit.go.jp/ksj/gml/data/N03/N03-2026/N03-20260101_56_GML.zip
GEOCODER_DB_PATH=/app/data/admin_area.sqlite
GEOCODER_OUTPUT_CSV=/app/output/geocoded_positions.csv

# Telop output
TELOP_OUTPUT_HOST=0.0.0.0
TELOP_OUTPUT_PORT=8030
TELOP_OUTPUT_URL=http://telop-output:8030
TELOP_CONFIG_PATH=/app/config/telop_config.json

# Host-side paths mounted into containers
HOST_OUTPUT_DIR=./output
HOST_INPUT_DIR=./input
HOST_GEOCODER_DATA_DIR=./reverse_geocoder/data
HOST_GEOCODER_OUTPUT_DIR=./reverse_geocoder/output
HOST_TELOP_CONFIG_DIR=./telop_output/config
HOST_TELOP_ASSETS_DIR=./telop_output/assets

# Start script display
START_OPEN_BROWSER=0
